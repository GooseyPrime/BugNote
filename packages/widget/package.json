  },
  "devDependencies": {
    "@bugnote/shared": "*",
    "jsdom": "^24.1.0",
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
