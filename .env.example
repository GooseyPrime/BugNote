# ---- Runtime ----
NODE_ENV=production
PORT=8090

# ---- Database (BugNote's OWN isolated database) ----
# Same Postgres engine as ResearchOne, separate db + role.
DATABASE_URL=postgresql://bugnote_app:CHANGEME@127.0.0.1:5432/bugnote

# ---- Ingest security ----
# Comma-separated origin allowlist for the embeddable widget.
INGEST_ALLOWED_ORIGINS=https://researchone.io,https://thenewontology.life
INGEST_RATE_LIMIT_PER_MIN=30
# Comma-separated origins for the review dashboard (Vercel URL).
ADMIN_ALLOWED_ORIGINS=https://bugnote-intellme.vercel.app

# ---- OpenRouter (model per pipeline stage; tune freely) ----
OPENROUTER_API_KEY=
OPENROUTER_MODEL_TRIAGE=
OPENROUTER_MODEL_ANALYSIS=
OPENROUTER_MODEL_FIX=
# Per-report hard cost ceiling in USD; pipeline halts and flags above this.
AGENT_COST_BUDGET_USD=0.50
# Minimum confidence (0-1) required to advance past analysis to PR generation.
AGENT_CONFIDENCE_GATE=0.6

# ---- GitHub App (draft PR generation) ----
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_WEBHOOK_SECRET=
# JSON map of app_id -> owner/repo, e.g. {"researchone":"GooseyPrime/ResearchOne"}
GITHUB_APP_REPO_MAP={}

# ---- Screenshot storage (dedicated DO Spaces bucket) ----
SPACES_ENDPOINT=
SPACES_BUCKET=bugnote-screenshots
SPACES_KEY=
SPACES_SECRET=

# ---- Dashboard auth (Google OAuth ID token + email allowlist) ----
GOOGLE_OAUTH_CLIENT_ID=
ADMIN_ALLOWED_EMAILS=
# Vercel dashboard project only:
# VITE_GOOGLE_OAUTH_CLIENT_ID=<same OAuth Web client ID>
# VITE_API_BASE_URL=https://api.bugnote.intellme.com
