{
  "name": "@bugnote/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts src/worker.ts --format esm --out-dir dist",
    "start:api": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@bugnote/shared": "*",
    "@bugnote/github-app": "*",
    "@aws-sdk/client-s3": "^3.600.0",
    "drizzle-orm": "^0.33.0",
    "fastify": "^4.28.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "pg": "^8.12.0",
    "pino": "^9.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.24.0",
    "tsup": "^8.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "@types/pg": "^8.11.0"
  }
}
